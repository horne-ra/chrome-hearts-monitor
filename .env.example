# ===== notification backend =====
NOTIFY_METHOD=discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXX/YYYY

# ===== monitor tuning (all optional; defaults shown) =====
# CH_POLL_SECONDS=30          # target seconds between sweep starts
# CH_MAX_INDIVIDUAL=8         # more new than this in one sweep -> single summary msg
# CH_STARTUP_PING=1           # send a "monitor online" Discord ping on boot

# ===== persistent state =====
# On Railway, attach a Volume mounted at /data and set:
# CH_STATE_FILE=/data/seen_products.json
# Locally you can leave this unset (defaults to ./seen_products.json).

# ----- alternate backends (only if NOTIFY_METHOD changed) -----
# Twilio:    TWILIO_ACCOUNT_SID / TWILIO_AUTH_TOKEN / TWILIO_FROM / TWILIO_TO
# email_sms: SMTP_HOST / SMTP_PORT / SMTP_USER / SMTP_PASS / SMS_TO
